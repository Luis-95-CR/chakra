# Copy this file to .env and fill in the values.

# --- Public site URL ---
# Used to build absolute URLs for social share cards (WhatsApp, etc.).
# Optional: defaults to https://la-chakra.org. On Vercel it falls back to the
# production deployment URL automatically.
NEXT_PUBLIC_SITE_URL="https://la-chakra.org"

# --- Admin access ---
# Password to log into /admin.
ADMIN_PASSWORD="change-me"

# Secret used to sign the session cookie (min 32 characters).
# Generate one with: openssl rand -base64 32
SESSION_SECRET="generate-a-long-random-string-min-32-chars"

# --- Storage (Upstash Redis) ---
# Leave EMPTY in local development to use the .data/catalog.json fallback.
# In production, set both from your Upstash Redis database.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
